pipeline {
agent { label 'slave' }
    stages {
        stage('Checkout') {
            steps {
                      sh 'rm -rf hello-world-war' 
                      sh 'git clone https://github.com/vineeth394/hello-world-war.git'
            }
        }
        stage('build') {
            steps {
                sh 'cd hello-world-war'
                sh 'mvn clean package'
            }
        }
    }
}
